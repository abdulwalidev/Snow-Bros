#wrap{display:flex;flex-direction:column;align-items:center;}
canvas{display:block;image-rendering:pixelated;border:2px solid #1a2a4a;}
#hint{color:#334;font-size:6px;letter-spacing:1px;text-align:center;margin-top:4px;opacity:.5;}

/* ── TOUCH UI ── */
#tui{
  position:fixed;bottom:0;left:0;right:0;height:160px;
