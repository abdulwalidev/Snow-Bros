.tbtn.on{transform:scale(.88);opacity:.7;}
#btn-j{background:radial-gradient(circle at 35% 35%,#3a88ff,#1a44bb);color:#c8e0ff;}
#btn-s{background:radial-gradient(circle at 35% 35%,#44ddff,#0a88aa);color:#e0faff;}
