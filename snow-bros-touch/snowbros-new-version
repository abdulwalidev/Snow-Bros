// ════════════════════════════════════════════════
//  ENTITY CLASSES
// ════════════════════════════════════════════════
class Player{
  constructor(){this.w=PW;this.h=PH;this.spawn();}
  spawn(){
    this.x=228;this.y=400;
    this.vx=0;this.vy=0;
    this.onGround=false;this.facing=1;
    this.shootCd=0;this.invTimer=90;this.dead=false;
    // power-up states
    this.powSpeed=0;    // red: speed boost timer
    this.powShotSpd=0;  // yellow: fast shots timer
    this.powShotPow=0;  // blue: power shots timer (more snow per hit)
  }
  get speed(){return this.powSpeed>0?5.2:3.6;}
  get shotSpeed(){return this.powShotSpd>0?11:7;}
  get shotPower(){return this.powShotPow>0?2:1;}
}

// Enemy types: 0=red walker, 1=green shooter, 2=purple jumper, 3=orange ghost(floats), 4=cyan shield(must hit 2x fast)
const ESPD=[1.0,1.4,0.8,0.6,1.8];
const ECOL=['#ee3322','#22bb44','#8844dd','#ff8800','#00ddee'];
const EHAT=['#881100','#116622','#441188','#884400','#007788'];
class Enemy{
  constructor(d){
    this.x=d.x;this.y=d.y;this.t=d.t;
    this.w=EW;this.h=EH;
    this.spd=ESPD[d.t];
    this.vx=(Math.random()>.5?1:-1)*this.spd;
    this.vy=0;this.onGround=false;
    this.snow=0;       // 0-3
    this.thawCd=0;
    this.isBall=false;
    this.ballVx=0;
    this.ballKills=0;
    this.ballLife=0;
    this.wallTaps=0;   // disappears after 3 wall taps
    this.dead=false;
    this.flashTick=0;
    this.wFrame=0;wTick=0;
    // AI
    this.jumpCd=80+Math.floor(Math.random()*160);
    this.shootCd=d.t===1?(120+Math.floor(Math.random()*160)):9999;
    this.shootDelay=0;
    this.dirCd=0;
    // type 3: ghost floater – bobs up/down, ignores gravity
    this.floatPhase=Math.random()*Math.PI*2;
    this.floatBase=d.y;
    // type 4: shield charger – has a shield that needs 2 hits to break before it can be frozen
    this.shield=d.t===4?2:0; // hits needed to break shield
  }
}

class Shot{
  constructor(x,y,vx,vy,owner,power=1){
    this.x=x;this.y=y;this.vx=vx;this.vy=vy||0;
    this.w=12;this.h=12;
    this.owner=owner; // 'player' or 'enemy'
    this.power=power;
    this.dead=false;this.age=0;
    this.trail=[];
  }
}

class Item{
  constructor(x,y,k){
    this.x=x;this.y=y;
    this.vy=-5.5;this.vx=(Math.random()-.5)*2;
    this.w=16;this.h=16;this.k=k;
    this.onGround=false;this.dead=false;
    this.life=400;this.tick=0;
  }
}

class Particle{
  constructor(x,y,vx,vy,col,life,sz=3){
    this.x=x;this.y=y;this.vx=vx;this.vy=vy;
    this.col=col;this.life=life;this.max=life;this.sz=sz;
  }
  step(){this.x+=this.vx;this.y+=this.vy;this.vy+=.18;this.vx*=.97;this.life--;}
  get dead(){return this.life<=0;}
}

class Pop{
  constructor(x,y,txt,col='#fff'){
    this.x=x;this.y=y;this.txt=txt;this.col=col;
    this.life=65;this.vy=-.75;
  }
  step(){this.y+=this.vy;this.life--;}
  get dead(){return this.life<=0;}
}

const BOSS_MAX_HP=20;
class Boss{
  constructor(){
    this.w=80;this.h=90;
    this.x=W/2-40;this.y=62;
    this.vx=1.2;this.vy=0;
    this.onGround=false;
    this.hp=BOSS_MAX_HP;
    this.dead=false;
    this.shootCd=180;
    this.flashTick=0;
    this.hitFlash=0;
  }
}

// ════════════════════════════════════════════════
