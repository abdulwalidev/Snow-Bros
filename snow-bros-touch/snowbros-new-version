function genStars(){
  bgStars=[];
  for(let i=0;i<45;i++) bgStars.push({x:Math.random()*W,y:52+Math.random()*(H-80),r:Math.random()});
}
genStars();

const PTS=[100,200,500,1000,2000,5000];

// ════════════════════════════════════════════════
//  PHYSICS
// ════════════════════════════════════════════════
function applyGrav(o){o.vy+=GRAV;if(o.vy>MAXFALL)o.vy=MAXFALL;}

function moveY(o){
  const py=o.y;
  o.y+=o.vy;
  o.onGround=false;
  for(const p of plats){
    if(o.x+o.w>p.x+2&&o.x<p.x+p.w-2){
      // land on top
      if(o.vy>=0&&py+o.h<=p.y+4&&o.y+o.h>=p.y){
        o.y=p.y-o.h;o.vy=0;o.onGround=true;
      }
      // bump head on bottom
      if(o.vy<0&&py>=p.y+p.h-4&&o.y<=p.y+p.h){
        o.y=p.y+p.h;o.vy=1.5;
      }
    }
  }
}

function moveXClamp(o){
  o.x+=o.vx;
  if(o.x<0){o.x=0;o.vx=0;}
  if(o.x+o.w>W){o.x=W-o.w;o.vx=0;}
}

function moveXBounce(o){
  o.x+=o.vx;
  if(o.x<=0){o.x=1;o.vx=Math.abs(o.vx);SFX.bounce();screenShake=3;if(o.wallTaps!==undefined){o.wallTaps++;}}
  if(o.x+o.w>=W){o.x=W-o.w-1;o.vx=-Math.abs(o.vx);SFX.bounce();screenShake=3;if(o.wallTaps!==undefined){o.wallTaps++;}}
}

// ════════════════════════════════════════════════
//  EFFECTS
// ════════════════════════════════════════════════
function snowBurst(x,y,n=8){
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,s=1.5+Math.random()*3.5;
    parts.push(new Particle(x,y,Math.cos(a)*s,Math.sin(a)*s-2,
      `hsl(${200+Math.random()*20},70%,${78+Math.random()*18}%)`,14+Math.random()*14,2+Math.random()*2));
  }
}
function deathBurst(x,y,col,n=16){
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,s=2+Math.random()*5;
    parts.push(new Particle(x,y,Math.cos(a)*s,Math.sin(a)*s-4,col,24+Math.random()*24,3+Math.random()*3));
  }
}
function sparkBurst(x,y,col,n=8){
  for(let i=0;i<n;i++){
    const a=(i/n)*Math.PI*2,s=2+Math.random()*3.5;
    parts.push(new Particle(x,y,Math.cos(a)*s,Math.sin(a)*s-2,col,12+Math.random()*12,2));
  }
}

