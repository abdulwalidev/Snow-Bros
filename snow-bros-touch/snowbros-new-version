function freezeEnemy(e){
  e.snow=3;e.isBall=false;e.vx=0;e.thawCd=420;e.flashTick=0;
  snowBurst(e.x+e.w/2,e.y+e.h/2,14);
  SFX.freeze();
}

function killEnemy(e,isChain=false){
  if(e.dead)return;
  e.dead=true;
  deathBurst(e.x+e.w/2,e.y+e.h/2,ECOL[e.t],16);
  screenShake=isChain?8:5;
  const pts=PTS[Math.min(combo,5)];
  combo++;comboTimer=90;
  score+=pts;if(score>hi)hi=score;
  pops.push(new Pop(e.x+e.w/2,e.y,pts+'',combo>2?'#ff8844':combo>1?'#ffee44':'#fff'));
  if(combo>=2)SFX.chain();else SFX.kill();
  if(Math.random()<.6)dropItem(e.x+e.w/2,e.y);
}

function dropItem(x,y){
  const r=Math.random();
  // k: 0=cherry(pts), 1=red(speed), 2=yellow(shot spd), 3=blue(shot pow), 4=1UP
  const k=r<.03?4:r<.2?3:r<.38?2:r<.56?1:0;
  items.push(new Item(x-8,y,k));
}

