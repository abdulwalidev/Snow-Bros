// ════════════════════════════════════════════════
let AC;
function ac(){return AC||(AC=new(window.AudioContext||window.webkitAudioContext)());}
function tone(f,d,v=.07,t='square',delay=0){
  try{
    const a=ac(),o=a.createOscillator(),g=a.createGain();
    o.type=t;o.frequency.value=f;
    const s=a.currentTime+delay;
    g.gain.setValueAtTime(v,s);
    g.gain.exponentialRampToValueAtTime(.001,s+d);
    o.connect(g);g.connect(a.destination);
    o.start(s);o.stop(s+d);
  }catch(e){}
}
const SFX={
  shoot : ()=>{tone(500,.06,.05,'sawtooth');tone(750,.07,.03,'square',.025);},
  freeze: ()=>{[220,330,440,550].forEach((f,i)=>tone(f,.16,.07,'sine',i*.05));},
  kick  : ()=>{tone(350,.09,.1,'square');tone(220,.08,.07,'square',.04);},
  kill  : ()=>{[523,659,784].forEach((f,i)=>tone(f,.1,.09,'square',i*.06));},
  chain : ()=>{[659,784,1047,1319].forEach((f,i)=>tone(f,.12,.09,'square',i*.065));},
  jump  : ()=>tone(600,.13,.05,'sine'),
  die   : ()=>{tone(220,.3,.1,'sawtooth');tone(150,.38,.07,'sawtooth',.06);},
  item  : ()=>{[880,1100].forEach((f,i)=>tone(f,.1,.07,'sine',i*.06));},
  bounce: ()=>tone(300,.07,.05,'square'),
  hit   : ()=>tone(280,.05,.08,'square'),
  clear : ()=>{[523,659,784,1047,1319,1568].forEach((f,i)=>tone(f,.18,.09,'square',i*.14));},
  start : ()=>{[262,330,392,523,659].forEach((f,i)=>tone(f,.18,.09,'square',i*.1));},
  coin  : ()=>{tone(880,.08,.08,'sine');tone(1100,.06,.06,'sine',.07);},
  eshoot: ()=>tone(200,.08,.04,'sawtooth'),
  power : ()=>{[440,550,660,880].forEach((f,i)=>tone(f,.12,.1,'sine',i*.07));},
};

// ════════════════════════════════════════════════
//  UTILITY
// ════════════════════════════════════════════════
function rr(x,y,w,h,r){
  r=Math.min(r,w/2,h/2);
  ctx.beginPath();
  ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);
  ctx.arcTo(x+w,y,x+w,y+r,r);ctx.lineTo(x+w,y+h-r);
  ctx.arcTo(x+w,y+h,x+w-r,y+h,r);ctx.lineTo(x+r,y+h);
  ctx.arcTo(x,y+h,x,y+h-r,r);ctx.lineTo(x,y+r);
  ctx.arcTo(x,y,x+r,y,r);ctx.closePath();ctx.fill();
}
function hits(a,b){
  return a.x<b.x+b.w&&a.x+a.w>b.x&&a.y<b.y+b.h&&a.y+a.h>b.y;
}
function clamp(v,lo,hi){return Math.max(lo,Math.min(hi,v));}

