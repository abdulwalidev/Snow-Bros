.s-label{color:#4a7aaa;font-size:6px;letter-spacing:.5px;}
.s-opt{display:flex;gap:6px;}
.s-opt button{
  background:rgba(20,40,80,.6);border:1px solid #2a4a7a;color:#4a7aaa;
